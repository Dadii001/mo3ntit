# Anthropic — required for all Claude analysis (vision, bio, song brief, DM)
ANTHROPIC_API_KEY=sk-ant-...

# RapidAPI TikTok scraper
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=tiktok-scraper7.p.rapidapi.com

# Monday.com
MONDAY_API_KEY=eyJ...
MONDAY_BOARD_ID=18409593345
MONDAY_GROUP_ID=topics

# Optional — OpenAI Whisper for song transcription. Without this, songs are saved
# with metadata but no transcript.
OPENAI_API_KEY=sk-...

# Optional — Supabase mirror. If both are set, every artist saved to Monday is
# also upserted into the public.artists table (richer fields than Monday).
# Run db/schema.sql once in Supabase to create the table.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
